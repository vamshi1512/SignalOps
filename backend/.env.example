ROBOYARD_APP_NAME=RoboYard Control
ROBOYARD_API_PREFIX=/api/v1
ROBOYARD_DATABASE_URL=postgresql+asyncpg://roboyard:roboyard@localhost:5432/roboyard_control
ROBOYARD_REDIS_URL=redis://localhost:6379/0
ROBOYARD_JWT_SECRET=roboyard-control-dev-secret-change-me-2026
ROBOYARD_JWT_EXPIRY_MINUTES=720
ROBOYARD_METRICS_ENABLED=true
ROBOYARD_SEED_ON_START=true
ROBOYARD_DEMO_MODE=true
ROBOYARD_DETERMINISTIC_MODE=true
ROBOYARD_SIMULATOR_TICK_SECONDS=1.0
ROBOYARD_TELEMETRY_FLUSH_INTERVAL=6
ROBOYARD_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
ROBOYARD_LOG_LEVEL=INFO
